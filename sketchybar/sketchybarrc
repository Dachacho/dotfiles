#!/bin/bash

PLUGIN_DIR="$CONFIG_DIR/plugins"

# Gruvbox Dark
BAR_COLOR=0xee282828
ITEM_BG_COLOR=0xff3c3836
ACCENT_COLOR=0xfffabd2f
TEXT_COLOR=0xffebdbb2
MUTED_TEXT=0xffa89984
TRANSPARENT=0x00000000

##### Bar #####
sketchybar --bar position=top \
                 height=36 \
                 blur_radius=20 \
                 color=$BAR_COLOR \
                 padding_left=8 \
                 padding_right=8

##### Defaults #####
default=(
  padding_left=4
  padding_right=4
  icon.font="JetBrainsMono Nerd Font:Bold:13.0"
  label.font="JetBrainsMono Nerd Font:Medium:13.0"
  icon.color=$TEXT_COLOR
  label.color=$TEXT_COLOR
  icon.padding_left=8
  icon.padding_right=4
  label.padding_left=4
  label.padding_right=8
  icon.y_offset=1
  label.y_offset=1
  background.color=$ITEM_BG_COLOR
  background.corner_radius=5
  background.height=24
)
sketchybar --default "${default[@]}"

##### Events #####
sketchybar --add event aerospace_workspace_change

##### Spaces #####
for sid in 1 2 3 4 5; do
  sketchybar --add item space.$sid left \
             --set space.$sid \
               icon="$sid" \
               icon.color=$MUTED_TEXT \
               icon.padding_left=9 \
               icon.padding_right=9 \
               icon.y_offset=1 \
               label.drawing=off \
               background.drawing=on \
               padding_left=2 \
               padding_right=2 \
               click_script="aerospace workspace $sid"
done

# Workspace change trigger
sketchybar --add item aerospace_trigger left \
           --set aerospace_trigger \
             drawing=off \
             script="$PLUGIN_DIR/aerospace.sh" \
           --subscribe aerospace_trigger aerospace_workspace_change

##### Front App (centered) #####
sketchybar --add item front_app center \
           --set front_app \
             icon.drawing=off \
             label.color=$TEXT_COLOR \
             label.y_offset=1 \
             label.padding_left=10 \
             label.padding_right=10 \
             background.drawing=on \
             script="$PLUGIN_DIR/front_app.sh" \
           --subscribe front_app front_app_switched

##### Right Items #####
sketchybar --add item clock right \
           --set clock \
             update_freq=10 \
             icon=ůįÉį \
             icon.color=$ACCENT_COLOR \
             background.drawing=on \
             script="$PLUGIN_DIR/clock.sh"

sketchybar --add item battery right \
           --set battery \
             update_freq=120 \
             icon.color=$ACCENT_COLOR \
             background.drawing=on \
             script="$PLUGIN_DIR/battery.sh" \
           --subscribe battery system_woke power_source_change

##### Initial Run #####
sketchybar --update
